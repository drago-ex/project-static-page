{
	"name": "drago-ex/project-auth",
	"type": "drago-tools-resource",
	"description": "Authentication and user access package for the Drago project.",
	"license": ["MIT"],
	"require": {
		"php": ">=8.3 <9",
		"drago-ex/database": "^3.0",
		"drago-ex/application": "^2.0",
		"drago-ex/form": "^2.0",
		"drago-ex/utils": "^2.0",
		"drago-ex/translator": "^3.0"
	},
	"extra": {
		"drago-tools": {
			"install": {
				"copy": {
					"resources/app": "app",
					"resources/assets": "assets"
				}
			},
			"commands-priority": 10,
			"commands": {
				"create:page-permission": "php vendor/bin/create-pate-permission",
				"db:migrate-page": "php vendor/bin/migration db:migrate vendor/drago-ex/project-static-page/migrations"
			}
		}
	},
	"require-dev": {
		"phpstan/phpstan-nette": "^2.0",
		"drago-ex/project-tools": "^1.0"
	},
	"bin": [
		"bin/create-user",
		"bin/create-page-permission"
	],
	"scripts": {
		"phpstan": "phpstan analyse",
		"post-install-cmd": [
			"drago-install --dev",
			"drago-clean"
		],
		"post-update-cmd": [
			"drago-install --dev",
			"drago-clean"
		]
	}
}
